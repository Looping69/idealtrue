# Optional local overrides
DISABLE_HMR="false"

# Local dev proxy target. The app now talks to Encore through a same-origin proxy and
# stores the session in an HttpOnly cookie. For local development the Express dev server
# falls back to http://127.0.0.1:4000 if this is unset, but setting it explicitly is clearer.
ENCORE_API_URL="http://127.0.0.1:4000"
VITE_GOOGLE_CLIENT_ID=""
VITE_GOOGLE_MAPS_API_KEY=""

# Vercel preview/production must set ENCORE_API_URL explicitly.
# Do not point production at a staging Encore backend.
# If you intentionally need that temporary fallback, set:
# ALLOW_STAGING_ENCORE_BACKEND="true"

# Gemini powers the trip planner chat, review summaries, and social content/image generation.
# Set this in both Vercel env vars and Encore runtime config:
# GEMINI_API_KEY
# Optional dedicated trip-planner/search AI override:
# SEARCH_AI_GEMINI_API_KEY
# SEARCH_AI_MODEL="gemini-2.5-flash-lite"
# Optional text fallback when Gemini is unavailable or rate-limited:
# DEEPSEEK_API_KEY
# Optional model overrides:
# GEMINI_TEXT_MODEL="gemini-2.5-flash"
# GEMINI_IMAGE_MODEL="gemini-2.5-flash-image"
# DEEPSEEK_TEXT_MODEL="deepseek-chat"

# Development-only auth escape hatch. Never enable this outside true local development.
# IDEAL_STAY_ENABLE_DEV_LOGIN="true"

# Optional shared-environment seed inputs.
# IDEAL_STAY_API_URL="https://your-encore-host"
# IDEAL_STAY_ALLOW_REMOTE_SEED="true"
# IDEAL_STAY_SEED_ADMIN_EMAIL="admin@example.com"
# IDEAL_STAY_SEED_ADMIN_PASSWORD="admin-password"
# IDEAL_STAY_DEMO_PASSWORD="IdealStayDemo123!"

# Optional live smoke verification inputs for preview/production hosts.
# IDEAL_STAY_RUN_LIVE_SMOKE="true"
# IDEAL_STAY_SMOKE_BASE_URL="https://your-preview-or-production-host"
# IDEAL_STAY_SMOKE_REQUIRE_ROLE_CREDENTIALS="true"
# IDEAL_STAY_SMOKE_EXPECT_LISTINGS_MIN="1"
# IDEAL_STAY_SMOKE_GUEST_EMAIL="guest.nomusa@idealstay.demo"
# IDEAL_STAY_SMOKE_GUEST_PASSWORD="IdealStayDemo123!"
# IDEAL_STAY_SMOKE_HOST_EMAIL="thandi.mokoena@idealstay.demo"
# IDEAL_STAY_SMOKE_HOST_PASSWORD="IdealStayDemo123!"
# IDEAL_STAY_SMOKE_ADMIN_EMAIL="admin@example.com"
# IDEAL_STAY_SMOKE_ADMIN_PASSWORD="admin-password"
# Optional throwaway signup probe:
# IDEAL_STAY_SMOKE_SIGNUP_EMAIL="smoke-guest@example.com"
# IDEAL_STAY_SMOKE_SIGNUP_PASSWORD="guest-password"
# IDEAL_STAY_SMOKE_SIGNUP_DISPLAY_NAME="Smoke Test Guest"
# IDEAL_STAY_SMOKE_SIGNUP_ROLE="guest"

# Backend runtime config
# Set these in Encore secrets or environment config for the backend service:
# YOCO_SECRET_KEY
# YOCO_WEBHOOK_SECRET
# AUTH_TOKEN_SECRET
# IDEAL_STAY_APP_URL
# RESEND_API_KEY
# AUTH_EMAIL_FROM
# AUTH_EMAIL_REPLY_TO
# GOOGLE_OAUTH_CLIENT_ID
# GEMINI_API_KEY