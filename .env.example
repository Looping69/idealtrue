# Optional local overrides
DISABLE_HMR="false"

# Default frontend behavior now targets Encore Cloud staging.
# Only set this if you explicitly want the app to talk to a different backend,
# for example a local Encore instance during backend development.
# VITE_ENCORE_API_URL="http://127.0.0.1:4000"
VITE_ENCORE_API_URL="https://staging-ideal-stay-online-gh5i.encr.app"

# Backend runtime config
# Set these in Encore secrets or environment config for the backend service:
# YOCO_SECRET_KEY
# YOCO_WEBHOOK_SECRET
# AUTH_TOKEN_SECRET
# IDEAL_STAY_APP_URL
